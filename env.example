# ============================================================
# Edge Score — 민감정보 설정 파일
# ============================================================
# 사용법:
#   1. 이 파일을 복사해서 .env 로 저장
#      cp .env.example .env
#   2. 아래 값들을 실제 값으로 채우세요
#   3. .env 는 절대 깃헙에 올리지 마세요 (.gitignore 에 포함됨)
# ============================================================

# ── 텔레그램 ─────────────────────────────────────────────
# BotFather 에서 발급받은 봇 토큰
TELEGRAM_TOKEN=여기에_봇토큰_입력

# 본인 텔레그램 chat_id (IDbot 에서 확인)
TELEGRAM_CHAT_ID=여기에_chat_id_입력

# ── 키움 REST API (발급 후 입력) ──────────────────────────
KIWOOM_APP_KEY=여기에_app_key_입력
KIWOOM_APP_SECRET=여기에_app_secret_입력
KIWOOM_ACCOUNT=여기에_계좌번호_입력

# 모의투자 여부 (true=모의, false=실계좌)
KIWOOM_MOCK=true
